<FilesMatch "^(\.env|config\.php|config\.local\.php|config\.local\.example\.php|helpers\.php)$">
  Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

  RewriteRule ^health/?$ health.php [QSA,L]
  RewriteRule ^auth/login/?$ auth/login.php [QSA,L]
  RewriteRule ^products/?([0-9]+)?$ products.php [QSA,L]
  RewriteRule ^upload/?$ upload.php [QSA,L]
  RewriteRule ^contact/?$ contact.php [QSA,L]
  RewriteRule ^enquiries/?([0-9]+)?$ enquiries.php [QSA,L]
</IfModule>
  RewriteRule ^uploads/([^/]+)/?$ uploads.php?file=$1 [QSA,L]
  RewriteRule ^contact/?$ contact.php [QSA,L]
  
  # Enquiries API
  RewriteRule ^enquiries/([0-9]+)/?$ enquiries.php?id=$1 [QSA,L]
  RewriteRule ^enquiries/?$ enquiries.php [QSA,L]
</IfModule>
